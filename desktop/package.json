{
  "name": "chatgpt-persian-rtl-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "ChatGPT Desktop RTL patcher for macOS and Windows.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "chatgpt-rtl-patcher": "bin/chatgpt-rtl-patcher.mjs"
  },
  "scripts": {
    "patch": "node bin/chatgpt-rtl-patcher.mjs",
    "restore": "node bin/chatgpt-rtl-patcher.mjs --restore",
    "patch:macos": "node bin/chatgpt-rtl-patcher.mjs --platform=macos",
    "restore:macos": "node bin/chatgpt-rtl-patcher.mjs --platform=macos --restore",
    "patch:windows": "node bin/chatgpt-rtl-patcher.mjs --platform=windows",
    "restore:windows": "node bin/chatgpt-rtl-patcher.mjs --platform=windows --restore",
    "rtl:launch": "node bin/codex-rtl-launcher.mjs",
    "rtl:canary": "node bin/codex-rtl-launcher.mjs --canary",
    "rtl:stop": "node bin/codex-rtl-stop.mjs",
    "classic:probe": "swift bin/codex-classic-probe.swift",
    "classic:rtl": "swift bin/codex-classic-rtl.swift --proof --send",
    "test": "node --check bin/chatgpt-rtl-patcher.mjs && node bin/chatgpt-rtl-patcher.test.mjs"
  },
  "dependencies": {
    "@electron/asar": "^3.2.18",
    "plist": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
